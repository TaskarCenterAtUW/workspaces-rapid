      // service - requires highway=* to match (issue Rapid#1252)
      // These are more specific than highway selectors (2 conditions vs 1), so they win
      "service-alley": {
        "styleIDs": ["special_service"],
        "match": { "tags": [{ "key": "service", "value": "alley" }, { "key": "highway" }] }
      },
