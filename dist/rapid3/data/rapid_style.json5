{
  // This file contains the Rapid style definitions.
  "assetID": "rapid_style",

  "scopes": [{
    "scope": "*",
    "styles": {
      // Default styles - used as fallback when no other style matches
      "DEFAULTS": {
        "fill":   { "width": 2, "color": 0xaaaaaa, "opacity": 0.3 },
        "casing": { "width": 5, "color": 0x444444, "opacity": 1, "cap": "round", "join": "round" },
        "stroke": { "width": 3, "color": 0xcccccc, "opacity": 1, "cap": "round", "join": "round" }
      }
    }

  }, {
    "scope": "osm",

    //
    // Variables
    // Named values that can be referenced by selectors using var() syntax.
    // Useful for defining reusable color palettes, value lists, etc.
    //
    // Opportunities for future variables:
    // - Color palette values (e.g. road casings, fill colors) shared across multiple styles
    // - Opacity presets (e.g. standard fill opacity, lifecycle opacity)
    // - Width presets (e.g. major road width, minor road width, path width)
    // - Tag value lists for selector matching (e.g. major highway values, water feature types)
    //
    "variables": {
    },

    //
    // Styles
    // A "Style" contains properties that describe how features should look.
    //
    // Available property groups:
    //   `fill`   - properties used when drawing fill (fill draws at the bottom)
    //   `casing` - properties used when drawing line (casing draws above fill)
    //   `stroke` - properties used when drawing line (stroke draws above casing)
    //
    // Available properties:
    //   `width` - line width in pixels (for fills, this is the width of the outline)
    //   `color` - the color as a hex literal, e.g. 0xcf2081
    //   `opacity` - 0 = transparent/invisible, 1 = filled
    //   `cap`   - one of 'butt', 'round', or 'square'
    //   `join`  - one of 'bevel', 'miter', or 'round'
    //   `dash`  - array of pixels on/off - e.g. [20, 5, 5, 5]
    //
    // The fill group also supports:
    //   `pattern` - supported pattern (see dist/img/pattern/* for these)
    //

    "styles": {
      // Lifecycle styles - e.g. planned, proposed, abandoned, disused, razed
      "LIFECYCLE": {
        "casing": { "opacity": 0 },  // disable casing
        "stroke": { "dash": [7, 3], "cap": "butt" }
      },

      // Generic color styles, mostly used for polygon filling.
      // We'll prefer to stick to this common limited color pallete rather than
      // trying to specify a different color for every possible map feature.
      // These colors should be relatively bright to contrast against background imagery.
      "red": {
        "fill":   { "color": 0xe06e5f, "opacity": 0.3 },  // rgb(224, 110, 95)
        "stroke": { "color": 0xe06e5f }
      },
      "green": {
        "fill":   { "color": 0x8cd05f, "opacity": 0.3 },  // rgb(140, 208, 95)
        "stroke": { "color": 0x8cd05f }
      },
      "blue": {
        "fill":   { "color": 0x77d4de, "opacity": 0.3 },  // rgb(119, 211, 222)
        "stroke": { "color": 0x77d4de }
      },
      "yellow": {
        "fill":   { "color": 0xffff94, "opacity": 0.25 }, // rgb(255, 255, 148)
        "stroke": { "color": 0xffff94 }
      },
      "gold": {
        "fill":   { "color": 0xc4be19, "opacity": 0.3 },  // rgb(196, 189, 25)
        "stroke": { "color": 0xc4be19 }
      },
      "orange": {
        "fill":   { "color": 0xd6881a, "opacity": 0.3 },  // rgb(214, 136, 26)
        "stroke": { "color": 0xd6881a }
      },
      "pink": {
        "fill":   { "color": 0xe3a4f5, "opacity": 0.3 },  // rgb(228, 164, 245)
        "stroke": { "color": 0xe3a4f5 }
      },
      "teal": {
        "fill":   { "color": 0x99e1aa, "opacity": 0.3 },  // rgb(153, 225, 170)
        "stroke": { "color": 0x99e1aa }
      },
      "lightgreen": {
        "fill":   { "color": 0xbee83f, "opacity": 0.3 },  // rgb(191, 232, 63)
        "stroke": { "color": 0xbee83f }
      },
      "tan": {
        "fill":   { "color": 0xf5dcba, "opacity": 0.3 },  // rgb(245, 220, 186)
        "stroke": { "color": 0xf5dcba }
      },
      "darkgray": {
        "fill":   { "color": 0x8c8c8c, "opacity": 0.5 },  // rgb(140, 140, 140)
        "stroke": { "color": 0x8c8c8c }
      },
      "lightgray": {
        "fill":   { "color": 0xaaaaaa, "opacity": 0.3 },  // rgb(170, 170, 170)
        "stroke": { "color": 0xaaaaaa }
      },
      "white": {
        "fill":   { "color": 0xffffff, "opacity": 0.3 },  // rgb(255, 255, 255)
        "stroke": { "color": 0xffffff }
      },

      "line_wide":   {
        "casing": { "width": 10 },
        "stroke": { "width": 8 }
      },
      "line_medium": {
        "casing": { "width": 7 },
        "stroke": { "width": 5 }
      },
      "line_narrow": {
        "casing": { "width": 5 },
        "stroke": { "width": 3 }
      },

      // Road styles - major roads
      "motorway": {
        "casing": { "color": 0x70372f },
        "stroke": { "color": 0xcf2081 }
      },
      "trunk": {
        "casing": { "color": 0x70372f },
        "stroke": { "color": 0xdd2f22 }
      },
      "primary": {
        "casing": { "color": 0x70372f },
        "stroke": { "color": 0xf99806 }
      },
      "secondary": {
        "casing": { "color": 0x70372f },
        "stroke": { "color": 0xf3f312 }
      },
      "tertiary": {
        "casing": { "color": 0x70372f },
        "stroke": { "color": 0xfff9b3 }
      },

      // Road styles - minor roads
      "unclassified": {
        "stroke": { "color": 0xddccaa }
      },
      "residential": {
        "stroke": { "color": 0xffffff }
      },
      "living_street": {
        "casing": { "color": 0xffffff },
        "stroke": { "color": 0xcccccc }
      },
      "service": {
        "stroke": { "color": 0xffffff }
      },
      "service_tagged": {
        "stroke": { "color": 0xddccaa }
      },
      "track": {
        "casing": { "color": 0x746f6f },
        "stroke": { "color": 0xc5b59f }
      },

      // Path styles - non-motorized traffic
      "pedestrian": {
        "label":  { "color": 0xffffff },
        "casing": { "color": 0xffffff },
        "stroke": { "color": 0x998888, "dash": [8, 8], "cap": "butt" }
      },
      "path": {
        "label":  { "color": 0xddccaa },
        "casing": { "color": 0xddccaa },
        "stroke": { "color": 0x998888, "dash": [6, 6], "cap": "butt" }
      },
      "footway": {
        "label":  { "color": 0xffffff },
        "casing": { "color": 0xffffff },
        "stroke": { "color": 0x998888, "dash": [6, 6], "cap": "butt" }
      },
      "crossing_default": {
        "label":  { "color": 0xddccaa },
        "casing": { "color": 0xddccaa },
        "stroke": { "color": 0x776a6a, "dash": [6, 4], "cap": "butt" }
      },
      "crossing_improved": {
        "label":  { "color": 0xddccaa },
        "casing": { "color": 0xddccaa },
        "stroke": { "color": 0x4c4444, "dash": [6, 3], "cap": "butt" }
      },
      "cycleway": {
        "label":  { "color": 0xffffff },
        "casing": { "color": 0xffffff },
        "stroke": { "color": 0x58a9ed, "dash": [6, 6], "cap": "butt" }
      },
      "bridleway": {
        "label":  { "color": 0xffffff },
        "casing": { "color": 0xffffff },
        "stroke": { "color": 0xe06d5f, "dash": [6, 6], "cap": "butt" }
      },
      "corridor": {
        "label":  { "color": 0xffffff },
        "casing": { "color": 0xffffff },
        "stroke": { "color": 0x8cd05f, "dash": [2, 8], "cap": "round" }
      },
      "steps": {
        "label":  { "color": 0xffffff },
        "casing": { "color": 0xffffff },
        "stroke": { "color": 0x81d25c, "dash": [3, 3], "cap": "butt" }
      },

      // Other linear features
      "waterway": {
        "fill":   { "color": 0x77d4de, "opacity": 0.3 },   // rgb(119, 211, 222)
        "stroke": { "color": 0x77dddd }
      },
      "runway": {
        "casing": { "color": 0x000000, "cap": "butt" },
        "stroke": { "color": 0xffffff, "dash": [24, 48], "cap": "butt" }
      },
      "taxiway": {
        "stroke": { "color": 0xffff00 }
      },
      "railway": {
        "casing": { "color": 0x555555, "width": 7, "cap": "butt" },
        "stroke": { "color": 0xeeeeee, "width": 2, "dash": [12, 12], "cap": "butt" }
      },
      "ferry": {
        "casing": { "opacity": 0 },  // disable casing
        "stroke": { "color": 0x58a9ed, "width": 3, "dash": [12, 8], "cap": "butt" }
      },
      "pipeline": {
        "stroke": { "color": 0xdddddd, "dash": [80, 2], "cap": "butt" }
      },
      "roller_coaster": {
        "stroke": { "color": 0xdddddd, "dash": [10, 1], "cap": "butt" }
      },

      // Boundary styles
      "boundary": {
        "casing": { "color": 0x82b5fe, "width": 6, "cap": "butt" },
        "stroke": { "color": 0xffffff, "width": 2, "dash": [20, 5, 5, 5], "cap": "butt" }
      },
      "boundary_park": {
        "casing": { "color": 0x82b5fe, "width": 6, "cap": "butt" },
        "stroke": { "color": 0xb0e298, "width": 2, "dash": [20, 5, 5, 5], "cap": "butt" }
      },

      // Barrier styles
      "barrier": {
        "casing": { "opacity": 0 },  // disable casing
        "stroke": { "color": 0xdddddd, "width": 3, "dash": [10, 5, 2, 5], "cap": "round" }
      },
      "barrier_wall": {
        "casing": { "opacity": 0 },  // disable casing
        "stroke": { "color": 0xdddddd, "width": 3, "dash": [10, 5, 2, 5], "cap": "round" }
      },
      "barrier_hedge": {
        "casing": { "opacity": 0 },  // disable casing
        "fill":   { "color": 0x8cd05f, "opacity": 0.3 },   // rgb(140, 208, 95)
        "stroke": { "color": 0x8cd05f, "width": 3, "dash": [10, 5, 2, 5], "cap": "round" }
      },

      // Miscellaneous
      "construction": {
        "casing": { "color": 0xffffff },
        "stroke": { "color": 0xfc6c14, "dash": [10, 10], "cap": "butt" }
      },

      // Pattern Styles
      "pattern-bushes":              { "fill": { "pattern": "bushes" } },
      "pattern-cemetery":            { "fill": { "pattern": "cemetery" } },
      "pattern-cemetery_buddhist":   { "fill": { "pattern": "cemetery_buddhist" } },
      "pattern-cemetery_christian":  { "fill": { "pattern": "cemetery_christian" } },
      "pattern-cemetery_jewish":     { "fill": { "pattern": "cemetery_jewish" } },
      "pattern-cemetery_muslim":     { "fill": { "pattern": "cemetery_muslim" } },
      "pattern-construction":        { "fill": { "pattern": "construction" } },
      "pattern-dots":                { "fill": { "pattern": "dots" } },
      "pattern-farmland":            { "fill": { "pattern": "farmland" } },
      "pattern-farmyard":            { "fill": { "pattern": "farmyard" } },
      "pattern-forest":              { "fill": { "pattern": "forest" } },
      "pattern-forest_broadleaved":  { "fill": { "pattern": "forest_broadleaved" } },
      "pattern-forest_leafless":     { "fill": { "pattern": "forest_leafless" } },
      "pattern-forest_needleleaved": { "fill": { "pattern": "forest_needleleaved" } },
      "pattern-grass":               { "fill": { "pattern": "grass" } },
      "pattern-landfill":            { "fill": { "pattern": "landfill" } },
      "pattern-lines":               { "fill": { "pattern": "lines" } },
      "pattern-orchard":             { "fill": { "pattern": "orchard" } },
      "pattern-pond":                { "fill": { "pattern": "pond" } },
      "pattern-quarry":              { "fill": { "pattern": "quarry" } },
      "pattern-vineyard":            { "fill": { "pattern": "vineyard" } },
      "pattern-waves":               { "fill": { "pattern": "waves" } },
      "pattern-wetland":             { "fill": { "pattern": "wetland" } },
      "pattern-wetland_bog":         { "fill": { "pattern": "wetland_bog" } },
      "pattern-wetland_marsh":       { "fill": { "pattern": "wetland_marsh" } },
      "pattern-wetland_reedbed":     { "fill": { "pattern": "wetland_reedbed" } },
      "pattern-wetland_swamp":       { "fill": { "pattern": "wetland_swamp" } }
    },


    //
    // Style Selectors
    // A "Style Selector" maps tag conditions to styles that will be applied.
    // All matching selectors are applied, those with a higher "weight" apply later.
    // Each selector has:
    // - match: conditions for matching (tags, geometry, dataset)
    // - styleIDs: array of style IDs to apply (merged in order, later styles override earlier)
    //
    // The `tags` array uses PropMatcher format:
    //   { key: 'highway', value: 'motorway' }  - exact match
    //   { key: 'building' }                    - key exists (any value)
    //

    "selectors": {
      // aeroway
      "aeroway-runway": {
        "styleIDs": ["runway", "line_wide"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "aeroway", "value": "runway" }]
        },
      },
      "aeroway-taxiway": {
        "styleIDs": ["taxiway", "line_medium"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "aeroway", "value": "taxiway" }]
        }
      },

      // amenity
      "amenity-education": {
        "styleIDs": ["yellow"],
        "match": {
          "tags": [{
            "key": "amenity",
            "op": "in",
            "value": ["childcare", "college", "kindergarten", "research_institute", "school", "university"]
          }]
        }
      },
      "amenity-fountain": {
        "styleIDs": ["blue", "pattern-pond"],
        "match": { "tags": [{ "key": "amenity", "value": "fountain" }] }
      },
      "amenity-grave_yard": {
        "styleIDs": ["lightgreen", "pattern-cemetery"],
        "match": { "tags": [{ "key": "amenity", "value": "grave_yard" }] }
      },
      "amenity-parking": {
        "styleIDs": ["darkgray"],
        "match": { "tags": [{ "key": "amenity", "value": "parking" }] }
      },

      // barrier
      "barrier-deafult": {
        "styleIDs": ["barrier"],
        "match": { "tags": [{ "key": "barrier" }] }
      },
      "barrier-wall": {
        "weight": 2,
        "styleIDs": ["barrier_wall"],
        "match": {
          "tags": [{
            "key": "barrier",
            "op": "in",
            "value": ["city_wall", "retaining_wall", "wall"]
          }]
        }
      },
      "barrier-hedge": {
        "weight": 2,
        "styleIDs": ["barrier_hedge"],
        "match": { "tags": [{ "key": "barrier", "value": "hedge" }] }
      },

      // boundary
      "boundary-default": {
        "weight": 0.9,
        "styleIDs": ["boundary"],
        "match": { "tags": [{ "key": "boundary" }] }
      },
      "boundary-protected_area": {
        "styleIDs": ["boundary_park"],
        "match": { "tags": [{ "key": "boundary", "value": "protected_area" }] }
      },
      "boundary-national_park": {
        "styleIDs": ["boundary_park"],
        "match": { "tags": [{ "key": "boundary", "value": "national_park" }] }
      },

      // crossings - darker strokes for crossings tagged with markings
      "crossing-default": {
        "styleIDs": ["crossing_default"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "crossing" }]
        }
      },
      "crossing-improved": {
        "weight": 2,
        "styleIDs": ["crossing_improved"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "crossing", "op": "in", "value": ["marked", "traffic_signals", "uncontrolled", "zebra"] }]
        }
      },
      "crossing-markings": {
        "weight": 2,
        "styleIDs": ["crossing_improved"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "crossing:markings" }]
        }
      },

      // golf
      "golf-grass": {
        "styleIDs": ["lightgreen", "pattern-grass"],
        "match": { "tags": [{ "key": "golf", "op": "in", "value": ["driving_range", "fairway", "green"] }] }
      },
      "golf-hole": {
        "styleIDs": ["lightgreen", "line_medium"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "golf", "value": "hole" }]
        }
      },
      "golf-rough": {
        "styleIDs": ["green", "pattern-grass"],
        "match": { "tags": [{ "key": "golf", "value": "rough" }] }
      },
      "golf-sand": {
        "styleIDs": ["yellow", "pattern-dots"],
        "match": { "tags": [{ "key": "golf", "value": "bunker" }] }
      },
      "golf-water": {
        "styleIDs": ["blue", "pattern-waves"],
        "match": { "tags": [{ "key": "golf", "op": "in", "value": ["lateral_water_hazard", "water_hazard"] }] }
      },

      // highway
      "highway-bridleway": {
        "styleIDs": ["bridleway", "line_narrow"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "bridleway" }]
        }
      },
      "highway-bus_guideway": {
        "styleIDs": ["railway"],  // note: style these like a railway
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "bus_guideway" }]
        }
      },
      "highway-busway": {
        "styleIDs": ["service_tagged", "line_medium"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "busway" }]
        }
      },
      "highway-corridor": {
        "styleIDs": ["corridor", "line_narrow"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "corridor" }]
        }
      },
      "highway-construction": {
        "styleIDs": ["construction", "line_wide"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "construction" }]
        }
      },
      "highway-cycleway": {
        "styleIDs": ["cycleway", "line_narrow"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "cycleway" }]
        }
      },
      "highway-footway": {
        "styleIDs": ["footway", "line_narrow"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "footway" }]
        }
      },
      "highway-living_street": {
        "styleIDs": ["living_street", "line_medium"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "living_street" }]
        }
      },
      "highway-motorway": {
        "styleIDs": ["motorway", "line_wide"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "op": "in", "value": ["motorway", "motorway_link"] }]
        }
      },
      "highway-path": {
        "styleIDs": ["path", "line_narrow"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "path" }]
        }
      },
      "highway-pedestrian": {
        "styleIDs": ["pedestrian", "line_medium"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "pedestrian" }]
        }
      },
      "highway-primary": {
        "styleIDs": ["primary", "line_wide"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "op": "in", "value": ["primary", "primary_link"] }]
        }
      },
      "highway-residential": {
        "styleIDs": ["residential", "line_wide"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "residential" }]
        }
      },
      "highway-secondary": {
        "styleIDs": ["secondary", "line_wide"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "op": "in", "value": ["secondary", "secondary_link"] }]
        }
      },
      "highway-service": {
        "styleIDs": ["service", "line_medium"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "service" }]
        }
      },
      // service roads - `highway=service` + `service=*`
      "highway-service-tagged": {
        "styleIDs": ["service_tagged", "line_medium"],
        "match": {
          "tags": [
            { "key": "highway", "value": "service" },
            { "key": "service" },
          ]
        }
      },
      "highway-steps": {
        "styleIDs": ["steps", "line_narrow"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "steps" }]
        }
      },
      "highway-tertiary": {
        "styleIDs": ["tertiary", "line_wide"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "op": "in", "value": ["tertiary", "tertiary_link"] }]
        }
      },
      "highway-track": {
        "styleIDs": ["track", "line_medium"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "track" }]
        }
      },
      "highway-trunk": {
        "styleIDs": ["trunk", "line_wide"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "op": "in", "value": ["trunk", "trunk_link"] }]
        }
      },
      "highway-unclassified": {
        "styleIDs": ["unclassified", "line_wide"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "highway", "value": "unclassified" }]
        }
      },

      // landuse
      "landuse-cemetery": {
        "styleIDs": ["lightgreen", "pattern-cemetery"],
        "match": { "tags": [{ "key": "landuse", "value": "cemetery" }] }
      },
      "landuse-commercial": {
        "styleIDs": ["orange"],
        "match": { "tags": [{ "key": "landuse", "value": "commercial" }] }
      },
      "landuse-construction": {
        "styleIDs": ["gold", "pattern-construction"],
        "match": { "tags": [{ "key": "landuse", "value": "construction" }] }
      },
      "landuse-farmland": {
        "styleIDs": ["lightgreen", "pattern-farmland"],
        "match": { "tags": [{ "key": "landuse", "value": "farmland" }] }
      },
      "landuse-farmyard": {
        "styleIDs": ["tan", "pattern-farmyard"],
        "match": { "tags": [{ "key": "landuse", "value": "farmyard" }] }
      },
      "landuse-forest": {
        "styleIDs": ["green", "pattern-forest"],
        "match": { "tags": [{ "key": "landuse", "value": "forest" }] }
      },
      "landuse-grass": {
        "styleIDs": ["green", "pattern-grass"],
        "match": { "tags": [{ "key": "landuse", "value": "grass" }] }
      },
      "landuse-grave_yard": {
        "styleIDs": ["lightgreen", "pattern-cemetery"],
        "match": { "tags": [{ "key": "landuse", "value": "grave_yard" }] }
      },
      "landuse-greenery": {
        "styleIDs": ["green"],
        "match": { "tags": [{
          "key": "landuse",
          "op": "in",
          "value": ["flowerbed", "recreation_ground", "village_green"]
        }] }
      },
      "landuse-industrial": {
        "styleIDs": ["pink"],
        "match": { "tags": [{ "key": "landuse", "value": "industrial" }] }
      },
      "landuse-landfill": {
        "styleIDs": ["orange", "pattern-landfill"],
        "match": { "tags": [{ "key": "landuse", "value": "landfill" }] }
      },
      "landuse-meadow": {
        "styleIDs": ["lightgreen", "pattern-grass"],
        "match": { "tags": [{ "key": "landuse", "value": "meadow" }] }
      },
      "landuse-military": {
        "styleIDs": ["orange", "pattern-construction"],
        "match": { "tags": [{ "key": "landuse", "value": "military" }] }
      },
      "landuse-orchard": {
        "styleIDs": ["lightgreen", "pattern-orchard"],
        "match": { "tags": [{ "key": "landuse", "value": "orchard" }] }
      },
      "landuse-quarry": {
        "styleIDs": ["darkgray", "pattern-quarry"],
        "match": { "tags": [{ "key": "landuse", "value": "quarry" }] }
      },
      "landuse-railway": {
        "styleIDs": ["darkgray"],
        "match": { "tags": [{ "key": "landuse", "value": "railway" }] }
      },
      "landuse-residential": {
        "styleIDs": ["gold"],
        "match": { "tags": [{ "key": "landuse", "value": "residential" }] }
      },
      "landuse-retail": {
        "styleIDs": ["orange"],
        "match": { "tags": [{ "key": "landuse", "value": "retail" }] }
      },
      "landuse-vineyard": {
        "styleIDs": ["lightgreen", "pattern-vineyard"],
        "match": { "tags": [{ "key": "landuse", "value": "vineyard" }] }
      },

      // leisure
      "leisure-greenery": {
        "styleIDs": ["green"],
        "match": { "tags": [{
          "key": "leisure",
          "op": "in",
          "value": ["garden", "golf_course", "nature_reserve", "park", "pitch"]
        }] }
      },
      "leisure-swimming_pool": {
        "styleIDs": ["blue", "pattern-lines"],
        "match": { "tags": [{ "key": "leisure", "value": "swimming_pool" }] }
      },
      "leisure-track": {
        "styleIDs": ["yellow"],
        "match": { "tags": [{ "key": "leisure", "value": "track" }] }
      },

      // man_made
      "man_made-adit": {
        "styleIDs": ["darkgray"],
        "match": { "tags": [{ "key": "man_made", "value": "adit" }] }
      },
      "man_made-breakwater": {
        "styleIDs": ["barrier_wall"],
        "match": { "tags": [{ "key": "man_made", "op": "in", "value": ["breakwater", "groyne"] }] }
      },
      "man_made-pipeline": {
        "styleIDs": ["pipeline", "line_medium"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "man_made", "value": "pipeline" }]
        }
      },

      // military (often dual-tagged with `landuse=military`, but not always)
      "military-default": {
        "styleIDs": ["orange"],
        "match": { "tags": [{ "key": "military" }] }
      },

      // natural
      "natural-default": {
        "weight": 0.9,
        "styleIDs": ["green"],
        "match": { "tags": [{ "key": "natural" }] }
      },
      "natural-glacier": {
        "styleIDs": ["lightgray"],
        "match": { "tags": [{ "key": "natural", "value": "glacier" }] }
      },
      "natural-grassland": {
        "styleIDs": ["green", "pattern-grass"],
        "match": { "tags": [{ "key": "natural", "value": "grassland" }] }
      },
      "natural-rock": {
        "styleIDs": ["darkgray"],
        "match": {
          "tags": [{
            "key": "natural",
            "op": "in",
            "value": ["bare_rock", "cave_entrance", "cliff", "ridge", "rock", "scree", "shingle", "stone"]
          }]
        }
      },
      "natural-sand": {
        "styleIDs": ["yellow", "pattern-dots"],
        "match": {
          "tags": [{
            "key": "natural",
            "op": "in",
            "value": ["beach", "sand"]
          }]
        }
      },
      "natural-scrub": {
        "styleIDs": ["yellow", "pattern-bushes"],
        "match": { "tags": [{ "key": "natural", "value": "scrub" }] }
      },
      "natural-water": {
        "styleIDs": ["blue", "pattern-waves"],
        "match": {
          "tags": [{
            "key": "natural",
            "op": "in",
            "value": ["bay", "strait", "water"]
          }]
        }
      },
      "natural-wetland": {
        "styleIDs": ["teal", "pattern-wetland"],
        "match": { "tags": [{ "key": "natural", "value": "wetland" }] }
      },
      "natural-wood": {
        "styleIDs": ["green", "pattern-forest"],
        "match": { "tags": [{ "key": "natural", "value": "wood" }] }
      },

      // power plant (often dual-tagged with `landuse=industrial`, but not always)
      "power-plant": {
        "styleIDs": ["pink"],
        "match": { "tags": [{ "key": "power", "value": "plant" }] }
      },

      // railway
      "railway-default": {
        "styleIDs": ["railway"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "railway" }]
        }
      },
      "railway-platform": {
        "weight": 2,
        "styleIDs": ["footway"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "railway", "value": "platform" }]
        }
      },

      // roller_coaster
      "roller_coaster-track": {
        "styleIDs": ["roller_coaster", "line_medium"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "roller_coaster", "value": "track" }]
        }
      },

      // route
      "route-ferry": {
        "styleIDs": ["ferry"],
        "match": {
          "geometry": "line",
          "tags": [{ "key": "route", "value": "ferry" }]
        }
      },

      // type
      "type-waterway": {
        "styleIDs": ["waterway", "line_wide"],
        "match": { "tags": [{ "key": "type", "value": "waterway" }] }
      },

      // waterway
      "waterway-default": {
        "styleIDs": ["waterway", "line_medium"],
        "match": { "tags": [{ "key": "waterway" }] }
      },
      "waterway-river": {
        "weight": 2,
        "styleIDs": ["waterway", "line_wide"],
        "match": { "tags": [{ "key": "waterway", "value": "river" }] }
      },
      "waterway-dam": {
        "weight": 2,
        "styleIDs": ["lightgray", "line_medium"],
        "match": { "tags": [{ "key": "waterway", "op": "in", "value": ["dam", "weir"] }] }
      },

      // "Override" selectors
      // These selectors are weighted higher and will override anything that matches earlier.

      // building - always style things with a building tag as red.
      "building-default": {
        "weight": 10,
        "styleIDs": ["red"],
        "match": { "tags": [{ "key": "building" }] }
      },

      // leaf_type overrides - apply specific pattern
      "leaf_type-broadleaved": {
        "weight": 5,
        "styleIDs": ["pattern-forest_broadleaved"],
        "match": { "tags": [{ "key": "leaf_type", "value": "broadleaved" }] }
      },
      "leaf_type-leafless": {
        "weight": 5,
        "styleIDs": ["pattern-forest_leafless"],
        "match": { "tags": [{ "key": "leaf_type", "value": "leafless" }] }
      },
      "leaf_type-needleleaved": {
        "weight": 5,
        "styleIDs": ["pattern-forest_needleleaved"],
        "match": { "tags": [{ "key": "leaf_type", "value": "needleleaved" }] }
      },

      // religion overrides - apply specific pattern
      "religion-buddhist": {
        "weight": 5,
        "styleIDs": ["pattern-cemetery_buddhist"],
        "match": { "tags": [{ "key": "religion", "value": "buddhist" }] }
      },
      "religion-christian": {
        "weight": 5,
        "styleIDs": ["pattern-cemetery_christian"],
        "match": { "tags": [{ "key": "religion", "value": "christian" }] }
      },
      "religion-jewish": {
        "weight": 5,
        "styleIDs": ["pattern-cemetery_jewish"],
        "match": { "tags": [{ "key": "religion", "value": "jewish" }] }
      },
      "religion-muslim": {
        "weight": 5,
        "styleIDs": ["pattern-cemetery_muslim"],
        "match": { "tags": [{ "key": "religion", "value": "muslim" }] }
      },

      // water overrides - apply specific pattern
      "water-pond": {
        "weight": 5,
        "styleIDs": ["pattern-pond"],
        "match": { "tags": [{ "key": "water", "value": "pond" }] }
      },
      "water-reservoir": {
        "weight": 5,
        "styleIDs": ["pattern-lines"],
        "match": { "tags": [{ "key": "water", "value": "reservoir" }] }
      },

      // wetland overrides - apply specific pattern
      "wetland-bog": {
        "weight": 5,
        "styleIDs": ["pattern-wetland_bog"],
        "match": { "tags": [{ "key": "wetland", "value": "bog" }] }
      },
      "wetland-marsh": {
        "weight": 5,
        "styleIDs": ["pattern-wetland_marsh"],
        "match": { "tags": [{ "key": "wetland", "value": "marsh" }] }
      },
      "wetland-reedbed": {
        "weight": 5,
        "styleIDs": ["pattern-wetland_reedbed"],
        "match": { "tags": [{ "key": "wetland", "value": "reedbed" }] }
      },
      "wetland-swamp": {
        "weight": 5,
        "styleIDs": ["pattern-wetland_swamp"],
        "match": { "tags": [{ "key": "wetland", "value": "swamp" }] }
      },

      // sport overrides - apply specific color
      "sport-sandy": {
        "weight": 5,
        "styleIDs": ["yellow"],
        "match": {
          "tags": [{
            "key": "sport",
            "op": "in",
            "value": [
              "baseball", "beachvolleyball", "bmx", "boules", "bullfighting", "cockfighting",
              "equestrian", "motocross", "softball", "speedway"
            ]
          }]
        }
      },
      "sport-pavement": {
        "weight": 5,
        "styleIDs": ["darkgray"],
        "match": {
          "tags": [{
            "key": "sport",
            "op": "in",
            "value": ["basketball", "skateboard"]
          }]
        }
      },

      // surface overrides - apply specific patterns
      "surface-grass": {
        "weight": 6,
        "styleIDs": ["pattern-grass"],
        "match": { "tags": [{ "key": "surface", "value": "grass" }] }
      },
      "surface-sand": {
        "weight": 6,
        "styleIDs": ["pattern-dots"],
        "match": { "tags": [{ "key": "surface", "value": "sand" }] }
      }
    }

  }]
}
